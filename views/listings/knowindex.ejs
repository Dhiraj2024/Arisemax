<%- layout("layout/boilerplate")  %>

<div class="content">
<div class="mortgage-content">
      <h2>I know in my life</h2>
      <% for(let know of allKnow) { %>
      <div class="mort-list-card card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center ">
          <div>
            <h5 class="card-title mb-1"><%= know.title %></h5>
            <p class="card-text text-muted mb-0"><%= know.description %></p>
          </div>
            <% if (currentUser && currentUser._id.toString() === know.owner.toString()) { %>
          <div class="d-flex ms-3 flex-shrink-0">
            <a href="/know/<%= know._id %>/edit" class="mort-btn-edit text-secondary me-3" title="Edit Entry">
              ✏️
            </a>
            <form method="POST" action="/know/<%= know._id %>?_method=DELETE" style="display:inline;">
              <button class="mort-btn-delete text-danger" title="Delete Entry" onclick="return confirm('Are you sure you want to delete this?')">
                🗑️
              </button>
            </form>
          </div>
                  <% } %>
        </div>
      </div>
      <% } %>
      <div class="mort-add-card card mt-4">
        <div class="card-body p-4 text-center">
          <a href="/know/new" class="d-inline-flex align-items-center">
            <span class="me-2" style="font-size: 1.25rem;">➕</span> Add New know Aims
          </a>
        </div>
      </div>
  </div>
</div>







