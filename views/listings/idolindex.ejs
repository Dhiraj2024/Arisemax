<%- layout("layout/boilerplate") %>
<div class="content">

<div class="content mx-auto my-4">
  <div class="idol-content">
    <h2 class="text-center mb-4">My Inspiration</h2>

    <div class="idol-cards d-flex flex-wrap justify-content-center gap-4">
      <% for(let idol of allIdol) { %>
      <div class="card idol-card shadow-sm">
        <img src="<%= idol.image.url %>" 
             class="card-img-top" 
             alt="image">
        <div class="card-body d-flex flex-column justify-content-between">
          <div>
            <h5 class="card-title text-center mb-2"><%= idol.title %></h5>
            <p class="card-text text-muted"><%= idol.description %></p>
          </div>

            <% if (currentUser && currentUser._id.toString() === idol.owner.toString()) { %>
          <div class="d-flex justify-content-end align-items-center gap-2 mt-2">
            <a href="/idol/<%= idol._id %>/edit" class="text-secondary" title="Edit Entry">
              ✏️
            </a>
            <form method="POST" action="/idol/<%= idol._id %>?_method=DELETE" style="display:inline;">
              <button class="btn p-0 text-danger border-0 bg-transparent" 
                      title="Delete Entry" 
                      onclick="return confirm('Are you sure you want to delete this?')">
                🗑️
              </button>
            </form>
          </div>
             <% } %>
        </div>
      </div>
      <% } %>

      <!-- Add new idol card -->
      <div class="card idol-card add-card text-center d-flex align-items-center justify-content-center shadow-sm">
        <a href="/idol/new" class="text-decoration-none text-dark">
          <span class="d-block fs-3">➕</span>
          <p class="m-0 fw-semibold">Add New Inspiration</p>
        </a>
      </div>
    </div>
  </div>
</div>
</div>



