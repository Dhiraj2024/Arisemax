<%- layout("layout/boilerplate")  %>
<div class="content">
<div class="mortgage-content">
      <h2>My GOALS</h2>

      <% for(let go of allGo) { %>
      <div class="mort-list-card card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center ">
          <div>
            <h5 class="card-title mb-1"><%= go.title %></h5>
            <p class="card-text text-muted mb-0"><%= go.description %></p>
          </div>

          <% if (currentUser && currentUser._id.toString() === go.owner.toString()) { %>
          <div class="d-flex ms-3 flex-shrink-0">
            <a href="/go/<%= go._id %>/edit" class="mort-btn-edit text-secondary me-3">
              ✏️
            </a>

            <form method="POST" action="/go/<%= go._id %>?_method=DELETE" style="display:inline;">
              <button class="mort-btn-delete text-danger">
                🗑️
              </button>
            </form>
          </div>
          <% } %>

        </div>
      </div>
      <% } %>

      <div class="mort-add-card card mt-4">
        <div class="card-body p-4 text-center">
          <a href="/go/new" class="d-inline-flex align-items-center">
            <span class="me-2" style="font-size: 1.25rem;">➕</span> Add New Goal
          </a>
        </div>
      </div>

  </div>
</div>

